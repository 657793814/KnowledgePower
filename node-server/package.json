{
  "name": "knowledgepower-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx src/seeders/index.ts",
    "migrate:mysql": "tsx scripts/migrate-from-mysql.ts",
    "ingest": "bash ../scripts/ingest.sh",
    "ingest:update": "bash ../scripts/ingest.sh --update-only",
    "ingest:stats": "bash ../scripts/ingest.sh --stats"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@zilliz/milvus2-sdk-node": "^3.0.3",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "multer": "^2.2.0",
    "mysql2": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.11.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
