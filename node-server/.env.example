# ZDKnowledge - 环境变量配置

# Server 端口
PORT=3001

# 数据库 (SQLite 默认)
DATABASE_URL=file:./prisma/knowledgepower.db

# MinIO 对象存储
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=zdknowledge
# 外部可访问的 MinIO 域名（生产环境改为 nginx 代理域名）
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# AI 配置（用于 embedding / 智能问答）
AI_API_BASE_URL=https://apihub.agnes-ai.com/v1
